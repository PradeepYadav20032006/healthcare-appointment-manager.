# ---- Server ----
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ---- Auth ----
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ---- Database (Postgres) ----
# Local docker-compose default. See README for docker-compose usage.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/healthcare_appointments?schema=public"

# ---- SMTP (email notifications) ----
# Any SMTP provider works: SendGrid, Mailgun, Gmail app password, Mailtrap (dev), etc.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM_EMAIL=no-reply@clinic.example.com
SMTP_FROM_NAME=City Clinic

# ---- LLM (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Google Calendar OAuth ----
# Create OAuth 2.0 credentials (Web application) in Google Cloud Console
# with this redirect URI registered exactly (used for BOTH patient and
# doctor connect flows - the callback controller is shared, and the
# `state` param tells it which user just authorized):
#   http://localhost:4000/api/patient/google/callback
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REDIRECT_URI=http://localhost:4000/api/patient/google/callback

# ---- Booking ----
SLOT_HOLD_TTL_MINUTES=5
